{
  "name": "saucedemo",
  "version": "1.0.0",
  "description": "Production-grade test automation framework for SauceDemo e-commerce application",
  "scripts": {
    "test": "cypress run",
    "test:headed": "cypress run --headed",
    "test:chrome": "cypress run --browser chrome",
    "test:open": "cypress open",
    "test:auth": "cypress run --spec 'cypress/e2e/auth.cy.js'",
    "test:catalog": "cypress run --spec 'cypress/e2e/product-catalog.cy.js'",
    "test:cart": "cypress run --spec 'cypress/e2e/shopping-cart.cy.js'",
    "test:checkout": "cypress run --spec 'cypress/e2e/checkout.cy.js'",
    "test:resilience": "cypress run --spec 'cypress/e2e/performance-resilience.cy.js'",
    "report:merge": "mochawesome-merge cypress/reports/json/*.json -o cypress/reports/merged-report.json",
    "report:generate": "marge cypress/reports/merged-report.json -f report -o cypress/reports/html --inline",
    "report": "npm run report:merge && npm run report:generate"
  },
  "devDependencies": {
    "cypress": "^13.17.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0"
  },
  "keywords": ["cypress", "e2e", "automation", "saucedemo", "testing"],
  "author": "Raihan Nahar Tofa",
  "license": "MIT"
}
